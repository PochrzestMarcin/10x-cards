---
import { Button } from "@/components/ui/button";
---

<div
  class="relative w-full mx-auto min-h-screen bg-background p-4 sm:p-8"
>
  <div
    class="relative max-w-4xl mx-auto rounded-2xl shadow-2xl p-8 bg-card text-card-foreground border"
  >
    <div class="space-y-12">
      <div class="text-center space-y-6">
        <h1
          class="text-6xl font-bold mb-4 text-primary"
        >
          Welcome to 10xCards!
        </h1>
        <p class="text-2xl text-muted-foreground max-w-2xl mx-auto">
          Create effective flashcards instantly with artificial intelligence
        </p>
      </div>

      <div class="flex flex-col gap-8 max-w-2xl mx-auto">
        <div class="rounded-xl p-6 border bg-card">
          <h2
            class="text-2xl font-semibold mb-4 text-primary"
          >
            Why 10xCards?
          </h2>
          <ul class="space-y-4">
            <li class="flex items-start space-x-3">
              <span class="text-primary text-2xl">✨</span>
              <span class="text-muted-foreground text-lg">Automatic flashcard generation from any text using AI</span>
            </li>
            <li class="flex items-start space-x-3">
              <span class="text-primary text-2xl">🎯</span>
              <span class="text-muted-foreground text-lg">Smart spaced repetition system adapted to your progress</span>
            </li>
            <li class="flex items-start space-x-3">
              <span class="text-primary text-2xl">⚡</span>
              <span class="text-muted-foreground text-lg">Save time - focus on learning, not creating flashcards</span>
            </li>
          </ul>
        </div>

        <div class="text-center space-y-6">
          <p class="text-xl text-muted-foreground">
            Join the community learning more effectively with AI
          </p>
          <div class="flex justify-center gap-4">
            <a href="/auth/register">
              <Button
                class="px-8 py-6 text-lg rounded-xl shadow-lg transition-all duration-200 hover:scale-105"
              >
                Sign up
              </Button>
            </a>
            <a href="/auth/login">
              <Button
                variant="outline"
                class="px-8 py-6 text-lg rounded-xl shadow-lg transition-all duration-200 hover:scale-105"
              >
                Sign in
              </Button>
            </a>
          </div>
        </div>
      </div>

      <div class="text-center">
        <p class="text-muted-foreground text-sm">
          Join thousands of users who have already discovered the effectiveness of learning with 10xCards
        </p>
      </div>
    </div>
  </div>
</div>
