---
import "../styles/global.css";
import { Toaster } from "@/components/ui/sonner";
import { Header } from "@/components/Header";

interface Props {
  title?: string;
  isAuthenticated?: boolean;
  userEmail?: string;
}

const { title = "10x Cards", isAuthenticated = false, userEmail } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      // Immediately-invoked script to set theme before any content loads
      (function() {
        function getThemePreference() {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        const theme = getThemePreference();

        // Add/remove class before any content loads to avoid FOIT
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }

        // Make theme available immediately to any script that needs it
        window.__theme = theme;
      })();
    </script>
  </head>
  <body>
    <div class="min-h-screen bg-background font-sans antialiased">
      <div class="px-8">
        <Header client:load isAuthenticated={isAuthenticated} userEmail={userEmail} />
        <main class="container py-6">
          <slot />
        </main>
      </div>
    </div>
    <Toaster richColors closeButton client:only="react" />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
