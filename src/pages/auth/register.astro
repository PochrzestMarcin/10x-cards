---
import Layout from '../../layouts/Layout.astro';
import { RegistrationForm } from '../../components/auth/RegistrationForm';

export const prerender = false;

// Note: Server-side auth validation will be added in next steps
---

<Layout title="Register - 10x Cards">
  <div class="container max-w-md mx-auto mt-8 px-4">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold tracking-tight">Create Account</h1>
      <p class="text-muted-foreground mt-2">Sign up to start creating flashcards</p>
    </div>
    <RegistrationForm client:load />
  </div>
</Layout>
