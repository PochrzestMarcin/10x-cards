---
import Layout from '../../layouts/Layout.astro';
import { PasswordResetForm } from '../../components/auth/PasswordResetForm';
import { NewPasswordForm } from '../../components/auth/NewPasswordForm';

export const prerender = false;

// Note: Server-side token validation will be added in next steps
const hasToken = Astro.url.searchParams.has('token');
---

<Layout title="Reset Password - 10x Cards">
  <div class="container max-w-md mx-auto mt-8 px-4">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold tracking-tight">
        {hasToken ? 'Set New Password' : 'Reset Password'}
      </h1>
      <p class="text-muted-foreground mt-2">
        {hasToken 
          ? 'Enter your new password below'
          : 'Enter your email to receive a password reset link'
        }
      </p>
    </div>
    {hasToken 
      ? <NewPasswordForm client:load />
      : <PasswordResetForm client:load />
    }
  </div>
</Layout>
