---
import Layout from "../layouts/Layout.astro";
import { createSupabaseServerInstance } from "../db/supabase.client";
import { FlashcardsView } from "../components/my-flashcards/FlashcardsView";

export const prerender = false;

const supabase = createSupabaseServerInstance({
  cookies: Astro.cookies,
  headers: Astro.request.headers,
});

const {
  data: { user },
} = await supabase.auth.getUser();

// Auth check is handled by middleware, but we'll double-check here
if (!user) {
  return Astro.redirect("/auth/login");
}
---

<Layout title="My Flashcards" isAuthenticated={!!user} userEmail={user.email} currentPath={Astro.url.pathname}>
  <main class="container mx-auto px-4 py-1">
    <h1 class="text-2xl font-bold mb-4">My Flashcards</h1>
    <FlashcardsView client:load />
  </main>
</Layout>
